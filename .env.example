# SlyTab configuration — copy to .env and fill in. NEVER commit .env.

# --- cPanel deploy (scripts/deploy-cpanel.mjs) ---
CPANEL_HOST=
CPANEL_PORT=2083
CPANEL_USER=
CPANEL_TOKEN=
# Remote path for the built SPA, e.g. /home/USER/public_html/slytab
WEB_ROOT=
# Remote path for the API front controller, e.g. /home/USER/public_html/slytab/api
API_WEB_ROOT=

# --- API runtime (api/) ---
# Local dev: the slytab-mysql container on kdocker2 (192.168.10.11:3306,
# db slytab_dev, user slytab) — see docs/dev-environment.md.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASS=
DB_ROOT_PASS=
# Receipt itemization: RECEIPT_ENGINE=auto prefers the local vision model
# (LOCAL_LLM_URL, ollama) and falls back to Claude only if a key is set.
RECEIPT_ENGINE=auto
LOCAL_LLM_URL=
LOCAL_LLM_MODEL=qwen2.5vl:7b
ANTHROPIC_API_KEY=
SESSION_PEPPER=
INVITE_HMAC_KEY=
MIGRATE_TOKEN=
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
