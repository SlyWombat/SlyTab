# SlySplit configuration — copy to .env and fill in. NEVER commit .env.

# --- cPanel deploy (scripts/deploy-cpanel.mjs) ---
CPANEL_HOST=
CPANEL_PORT=2083
CPANEL_USER=
CPANEL_TOKEN=
# Remote path for the built SPA, e.g. /home/USER/public_html/slysplit
WEB_ROOT=
# Remote path for the API front controller, e.g. /home/USER/public_html/slysplit/api
API_WEB_ROOT=

# --- API runtime (api/) ---
DB_HOST=localhost
DB_NAME=
DB_USER=
DB_PASS=
ANTHROPIC_API_KEY=
SESSION_PEPPER=
INVITE_HMAC_KEY=
MIGRATE_TOKEN=
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
